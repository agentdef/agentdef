# --- Graph ---

def build_graph() -> StateGraph:
    """Construct the agent execution graph."""
    graph = StateGraph(AgentState)

    graph.add_node("input_analysis", input_analysis)
    graph.add_node("clarification_check", clarification_check)
    graph.add_node("structure_drafting", structure_drafting)
    graph.add_node("gap_filling", gap_filling)
    graph.add_node("review_and_polish", review_and_polish)
    graph.add_node("final_output", final_output)
    graph.add_node("mission_author", mission_author)

    graph.set_entry_point("input_analysis")
    graph.add_edge("input_analysis", "clarification_check")
    graph.add_edge("clarification_check", "structure_drafting")
    graph.add_edge("structure_drafting", "gap_filling")
    graph.add_edge("gap_filling", "review_and_polish")
    graph.add_edge("review_and_polish", "final_output")
    graph.add_edge("final_output", "mission_author")
    graph.add_edge("mission_author", END)

    return graph


