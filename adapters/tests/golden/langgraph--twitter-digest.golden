# --- Graph ---

def build_graph() -> StateGraph:
    """Construct the agent execution graph."""
    graph = StateGraph(AgentState)

    graph.add_node("ingestion", ingestion)
    graph.add_node("content_extraction", content_extraction)
    graph.add_node("filtering", filtering)
    graph.add_node("topic_clustering", topic_clustering)
    graph.add_node("prioritization", prioritization)
    graph.add_node("editorial_synthesis", editorial_synthesis)
    graph.add_node("final_report", final_report)
    graph.add_node("summarization", summarization)

    graph.set_entry_point("ingestion")
    graph.add_edge("ingestion", "content_extraction")
    graph.add_edge("content_extraction", "filtering")
    graph.add_edge("filtering", "topic_clustering")
    graph.add_edge("topic_clustering", "prioritization")
    graph.add_edge("prioritization", "editorial_synthesis")
    graph.add_edge("editorial_synthesis", "final_report")
    graph.add_edge("final_report", "summarization")
    graph.add_edge("summarization", END)

    return graph


if __name__ == "__main__":
    g = build_graph()
    app = g.compile()
    result = app.invoke({"input": "", "output": "", "context": {}})
